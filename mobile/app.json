{
  "expo": {
    "name": "Friendminton",
    "slug": "friendminton-mobile",
    "scheme": "friendminton",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Friendminton uses your location to find nearby players, sessions, and socials.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.hcharlie1201.friendminton"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "react-native-maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Friendminton uses your location to find nearby players, sessions, and socials."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Friendminton lets you choose photos for badminton posts and gathering covers."
        }
      ],
      "expo-font",
      "expo-status-bar",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "googleMapsProvider": "google",
      "router": {},
      "eas": {
        "projectId": "1cb0ab76-b933-4868-bd10-0903eeedf8fb"
      }
    }
  }
}
